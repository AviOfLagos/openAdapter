# Dependencies
node_modules/
**/node_modules/

# Lockfiles (only root pnpm-lock.yaml is tracked)
package-lock.json
yarn.lock
apps/*/pnpm-lock.yaml
packages/*/pnpm-lock.yaml

# Build outputs
dist/
.next/
.turbo/
*.tsbuildinfo

# Environment
.env
.env.local
.env*.local

# OpenAdapter specific
.browser-profile/
temp_uploads/
apps/server/temp_uploads/
logs.txt
apps/server/logs.txt

# OS files
.DS_Store
*.log

# Docs (generated)
docs/

# Note: .github/ directory IS tracked (contains workflows and templates)
