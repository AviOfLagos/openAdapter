# ============================================
# OpenAdapter Dashboard Configuration
# ============================================

# OpenAdapter Server URL (REQUIRED)
# NEXT_PUBLIC_ prefix makes this available on client side
# The dashboard connects to this URL for health monitoring, logs, and controls
NEXT_PUBLIC_OPENADAPTER_SERVER_URL=http://127.0.0.1:3001

# OpenAdapter Admin API Key (OPTIONAL)
# Only needed if your OpenAdapter server requires authentication
# Leave empty if ADMIN_API_KEY is not set on the server
OPENADAPTER_ADMIN_API_KEY=

# NextAuth Secret (REQUIRED)
# Generate with: openssl rand -base64 32
# Or visit: https://generate-secret.vercel.app/32
AUTH_SECRET=****

# ============================================
# Optional: Advanced Features
# ============================================
# The following are only needed for advanced dashboard features
# like chat history, file uploads, and rate limiting.
# Basic monitoring (Activities, Logs, Settings) works without these.

# Vercel AI Gateway API Key
# Required for: Chat functionality with AI models
# Get yours at: https://vercel.com/ai-gateway
# AI_GATEWAY_API_KEY=****

# PostgreSQL Database
# Required for: Chat history persistence
# Get yours at: https://vercel.com/docs/postgres
# POSTGRES_URL=****

# Vercel Blob Storage
# Required for: File upload attachments
# Get yours at: https://vercel.com/docs/vercel-blob
# BLOB_READ_WRITE_TOKEN=****

# Redis
# Required for: Rate limiting
# Get yours at: https://vercel.com/docs/redis
# REDIS_URL=****
