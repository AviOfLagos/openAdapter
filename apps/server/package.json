{
  "name": "@openadapter/server",
  "version": "1.0.0",
  "private": true,
  "description": "OpenAdapter Express server - Claude.ai to OpenAI API Bridge",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "npm run test:unit && node src/server.js",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:integration": "node --test tests/integration/**/*.test.js",
    "clean": "rm -rf node_modules temp_uploads logs.txt"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mime-types": "^3.0.2",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "jsdom": "^24.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
